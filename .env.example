# Phase 5 — Response Generation (Ollama, local)

# Set to true to enable LLM-generated replies (requires Ollama running).
RESPONSE_GENERATOR_ENABLED=false

# ollama | none
LLM_PROVIDER=none

OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2

# Phase 4 (optional, improves NVD rate limits)
# NVD_API_KEY=

# Phase 2/3
# NLU_MODEL_FAMILY=bert
