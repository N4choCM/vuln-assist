# VulnAssist — VPS full stack (deploy/docker-compose.yml)
# Copy to repo root: cp .env.example .env

# Phase 8 — Response generation (Ollama on internal Docker network)
RESPONSE_GENERATOR_ENABLED=true
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.2
# OLLAMA_TIMEOUT_SECONDS=120

# Phase 4 — NVD rate limits (strongly recommended for public demo)
# NVD_API_KEY=

# Phase 2/3 — NLU checkpoints mounted from models/nlu/
NLU_MODEL_FAMILY=bert
