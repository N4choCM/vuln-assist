# FastAPI backend with NLU inference (Torch lazy-loaded on first predict).
FROM python:3.11-slim

WORKDIR /app

# curl is used by the compose healthcheck.
RUN apt-get update \
    && apt-get install -y --no-install-recommends curl \
    && rm -rf /var/lib/apt/lists/*

COPY requirements-prod.txt .
RUN pip install --no-cache-dir -r requirements-prod.txt

COPY backend/ backend/
COPY services/ services/
COPY integrations/ integrations/
COPY config/ config/
COPY data/knowledge_base/ data/knowledge_base/
# Runtime NLU imports label constants from data.dataset (not the full pipeline).
COPY data/__init__.py data/__init__.py
COPY data/dataset/__init__.py data/dataset/__init__.py
COPY data/dataset/labels.py data/dataset/labels.py

EXPOSE 8000

CMD ["uvicorn", "backend.api.main:app", "--host", "0.0.0.0", "--port", "8000", "--workers", "1"]
